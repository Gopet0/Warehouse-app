@model IEnumerable<Warehouse.Models.StockTransaction>
@{
    ViewBag.Title = "Transactions";
}

<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
    <h1>Stock Transactions</h1>
    <a href__="/StockTransaction/Create" class="btn btn-primary">+ New Transaction</a>
</div>

<table>
    <tr>
        <th>Type</th>
        <th>Product</th>
        <th>Quantity</th>
        <th>Supplier</th>
        <th>Date</th>
        <th>Notes</th>
    </tr>
    @foreach (var item in Model)
    {
        <tr>
            <td>
                @if (item.Type == "stock_in")
                {
                    <span class="badge badge-success">Stock In</span>
                }
                else
                {
                    <span class="badge badge-warning">Stock Out</span>
                }
            </td>
            <td>@(item.Product != null ? item.Product.Name : "N/A")</td>
            <td>@item.Quantity</td>
            <td>@(item.Supplier != null ? item.Supplier.CompanyName : "—")</td>
            <td>@item.TransactionDate.ToString("dd MMM yyyy")</td>
            <td>@item.Notes</td>
        </tr>
    }
</table>