@{
    ViewBag.Title = "Dashboard";
}

<h1>Dashboard</h1>

<div class="stats-grid">
    <div class="stat-card">
        <h3>@ViewBag.TotalProducts</h3>
        <p>Total Products</p>
    </div>
    <div class="stat-card">
        <h3>@ViewBag.TotalSuppliers</h3>
        <p>Total Suppliers</p>
    </div>
    <div class="stat-card" style="border-top-color: #e74c3c;">
        <h3>@ViewBag.LowStock</h3>
        <p>Low Stock Items</p>
    </div>
    <div class="stat-card" style="border-top-color: #27ae60;">
        <h3>@ViewBag.TotalTransactions</h3>
        <p>Transactions</p>
    </div>
</div>

<div class="card">
    <h2>Quick Links</h2>
    <p style="margin-bottom:16px;">Navigate to a section to manage your inventory.</p>
    <a href__="/Product/Create" class="btn btn-primary" style="margin-right:10px;">+ Add Product</a>
    <a href__="/Supplier/Create" class="btn btn-success" style="margin-right:10px;">+ Add Supplier</a>
    <a href__="/StockTransaction/Create" class="btn btn-warning">+ New Transaction</a>
</div>