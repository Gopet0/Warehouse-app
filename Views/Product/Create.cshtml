@model Product
@{
    ViewBag.Title = "Add Product";
}

<h1>Add Product</h1>

<div class="card">
    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        @Html.ValidationSummary(true, "", new { @class = "validation-summary-errors" })

        <div class="form-group">
            @Html.LabelFor(m => m.Name)
            @Html.TextBoxFor(m => m.Name)
            @Html.ValidationMessageFor(m => m.Name, "", new { @class = "field-validation-error" })
        </div>
        <div class="form-group">
            @Html.LabelFor(m => m.SKU)
            @Html.TextBoxFor(m => m.SKU)
            @Html.ValidationMessageFor(m => m.SKU, "", new { @class = "field-validation-error" })
        </div>
        <div class="form-group">
            @Html.LabelFor(m => m.Category)
            @Html.DropDownListFor(m => m.Category, new SelectList(new[] {
                "Electronics","Furniture","Clothing","Food & Beverage",
                "Raw Materials","Packaging","Tools","Chemicals","Spare Parts","Other"
            }), "-- Select Category --")
        </div>
        <div class="form-group">
            @Html.LabelFor(m => m.Quantity)
            @Html.TextBoxFor(m => m.Quantity, new { type = "number", min = "0" })
        </div>
        <div class="form-group">
            @Html.LabelFor(m => m.MinQuantity)
            @Html.TextBoxFor(m => m.MinQuantity, new { type = "number", min = "0" })
        </div>
        <div class="form-group">
            @Html.LabelFor(m => m.UnitPrice)
            @Html.TextBoxFor(m => m.UnitPrice, new { type = "number", min = "0", step = "0.01" })
        </div>
        <div class="form-group">
            @Html.LabelFor(m => m.WarehouseLocation)
            @Html.TextBoxFor(m => m.WarehouseLocation)
        </div>
        <div class="form-group">
            @Html.LabelFor(m => m.Description)
            @Html.TextAreaFor(m => m.Description, 3, 0, null)
        </div>

        <button type="submit" class="btn btn-primary">Save</button>
        <a href="/Product" class="btn btn-danger" style="margin-left:10px;">Cancel</a>
    }
</div>
