@model LoginViewModel
@{
    ViewBag.Title = "Log in";
}

<center><h1>Log in</h1>

<div class="card" style="max-width:420px;">
    <form asp-action="Login" asp-controller="Account" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="ReturnUrl" />

        <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

        <div class="form-group">
            <label asp-for="Email"></label>
            <input asp-for="Email" autocomplete="username" />
            <span asp-validation-for="Email" class="field-validation-error"></span>
        </div>
        <div class="form-group">
            <label asp-for="Password"></label>
            <input asp-for="Password" autocomplete="current-password" />
            <span asp-validation-for="Password" class="field-validation-error"></span>
        </div>
        <div class="form-group checkbox-row">
            <label>
                <input asp-for="RememberMe" />
                @Html.DisplayNameFor(m => m.RememberMe)
            </label>
        </div>

        <button type="submit" class="btn btn-primary">Log in</button>
        <a href="/Account/Register" class="btn btn-success" style="margin-left:10px;">Register</a>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" /></center>
}
