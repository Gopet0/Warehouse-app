@model StockTransaction
@{
    ViewBag.Title = "New Transaction";
}

<h1>New Stock Transaction</h1>

<div class="card">
    @using (Html.BeginForm("Create", "StockTransaction", FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        @Html.ValidationSummary(false, "", new { @class = "validation-summary-errors" })

        <div class="form-group">
            <label asp-for="Type"></label>
            @Html.DropDownListFor(m => m.Type, new SelectList(new[] {
                new { Value = "stock_in", Text = "Stock In" },
                new { Value = "stock_out", Text = "Stock Out" }
            }, "Value", "Text"), "-- Select Type --")
            @Html.ValidationMessageFor(m => m.Type, "", new { @class = "field-validation-error" })
        </div>
        <div class="form-group">
            <label asp-for="ProductId"></label>
            @Html.DropDownListFor(m => m.ProductId, (SelectList)ViewBag.ProductId!, "-- Select Product --")
            @Html.ValidationMessageFor(m => m.ProductId, "", new { @class = "field-validation-error" })
        </div>
        <div class="form-group">
            <label asp-for="Quantity"></label>
            @Html.TextBoxFor(m => m.Quantity, new { type = "number", min = "1", step = "1" })
            @Html.ValidationMessageFor(m => m.Quantity, "", new { @class = "field-validation-error" })
        </div>
        <div class="form-group">
            <label asp-for="SupplierId"></label>
            @Html.DropDownListFor(m => m.SupplierId, (SelectList)ViewBag.SupplierId!, "-- None --")
            @Html.ValidationMessageFor(m => m.SupplierId, "", new { @class = "field-validation-error" })
        </div>
        <div class="form-group">
            <label asp-for="Notes"></label>
            @Html.TextAreaFor(m => m.Notes, 3, 0, null)
        </div>

        <button type="submit" class="btn btn-primary">Record Transaction</button>
        <a href="/StockTransaction" class="btn btn-danger" style="margin-left:10px;">Cancel</a>

        
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
